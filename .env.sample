# ══════════════════════════════════════════════════════════════════════════════
# NSID Kenya — Environment Configuration
# SoilFER Project GCP/GLO/1127/USA
# Copy to .env and fill in values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=nsis_kenya

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=nsis_kenya.settings
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
DEBUG=True

# ── Site URL (change for production) ─────────────────────────────────────────
# Local dev:
SITEURL=http://localhost/
DJANGO_HOSTNAME=localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (KALRO server):
# SITEURL=https://nsid.kalro.go.ke/
# DJANGO_HOSTNAME=nsid.kalro.go.ke
# ALLOWED_HOSTS=nsid.kalro.go.ke,www.nsid.kalro.go.ke
# DOCKER_ENV=production
# HTTPS_HOST=nsid.kalro.go.ke
# LETSENCRYPT_MODE=production
# LETSENCRYPT_EMAIL=admin@kalro.go.ke

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_HOST=db
DATABASE_PORT=5432

GEONODE_DATABASE=nsis_kenya
GEONODE_DATABASE_USER=geonode
GEONODE_DATABASE_PASSWORD=CHANGE_ME

GEONODE_GEODATABASE=nsis_kenya_data
GEONODE_GEODATABASE_USER=geonode
GEONODE_GEODATABASE_PASSWORD=CHANGE_ME

POSTGRES_PASSWORD=CHANGE_ME

# ── GeoServer ─────────────────────────────────────────────────────────────────
GEOSERVER_WEB_UI_LOCATION=http://localhost/geoserver/
GEOSERVER_PUBLIC_LOCATION=http://localhost/geoserver/
GEOSERVER_LOCATION=http://geoserver:8080/geoserver/
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── OAuth2 (generate with: python manage.py generate_oauth_keys) ──────────────
OAUTH2_CLIENT_ID=CHANGE_ME
OAUTH2_CLIENT_SECRET=CHANGE_ME

# ── Email ─────────────────────────────────────────────────────────────────────
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@nsid.kalro.go.ke
# EMAIL_HOST=smtp.kalro.go.ke
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ── GeoNode map defaults — Kenya centroid ────────────────────────────────────
DEFAULT_MAP_CRS=EPSG:4326
DEFAULT_MAP_CENTER_X=37.906
DEFAULT_MAP_CENTER_Y=0.023
DEFAULT_MAP_ZOOM=6
